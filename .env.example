# Provedor de modelo: "gemini" ou "ollama"
MODEL_PROVIDER=gemini

# --- Gemini API (usar quando MODEL_PROVIDER=gemini) ---
GEMINI_API_KEY=sua_chave_aqui
GEMINI_MODEL=gemini-2.0-flash

# --- Ollama local (usar quando MODEL_PROVIDER=ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:0.6b

# --- Configurações do agente ---
SESSION_ID=spectra-cli
DB_PATH=spectra.db

# --- Interface web (app.py) ---
FLASK_SECRET_KEY=troque-por-uma-string-aleatoria
FLASK_PORT=5000
